NEXT_PUBLIC_API_URL=http://localhost:8069
# Remote dev example:
# NEXT_PUBLIC_API_URL=https://crm-odoo-demo.tongla.dev
# Browser calls /api/* on the Next.js app; Next.js rewrites to NEXT_PUBLIC_API_URL/api/*
# Request timeout in milliseconds (default: 30000)
# NEXT_PUBLIC_API_TIMEOUT_MS=30000
# Restart `npm run dev` after changing this value.

# Typhoon OCR API key, used server-side only by app/api/ocr/route.ts
# (never exposed to the browser). Get one at https://opentyphoon.ai
TYPHOON_OCR_API_KEY=
